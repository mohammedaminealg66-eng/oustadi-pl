FROM node:22-alpine
RUN apk add --no-cache python3 make g++
WORKDIR /app
RUN corepack enable && corepack prepare pnpm@latest --activate
COPY . .
RUN pnpm install
RUN cd apps/api && npx prisma generate
RUN pnpm --filter @oustadi/api run build
EXPOSE 3000
RUN printf '#!/bin/sh\ncd apps/api && npx prisma db push --accept-data-loss && node dist/main.js\n' > /entrypoint.sh && chmod +x /entrypoint.sh
CMD ["/entrypoint.sh"]

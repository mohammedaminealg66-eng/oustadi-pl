# Database
DATABASE_URL=postgresql://oustadi:changeme@localhost:5432/oustadi

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-this-to-a-random-64-character-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# App
NODE_ENV=development
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000

# ─── SMTP (Email) ──────────────────────────────────
# Required for: verification emails, password reset, notifications
#
# Option A: Real SMTP (production)
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=your-email@gmail.com
#   SMTP_PASS=your-gmail-app-password   (NOT your regular password — create an App Password)
#   SMTP_FROM=your-email@gmail.com
#
# Option B: Maildev (local dev — captures all emails in a web UI at http://localhost:1080)
#   Run: docker compose -f infra/docker-compose.dev.yml up -d maildev
#   Then set:
#   SMTP_HOST=localhost
#   SMTP_PORT=1025
#   SMTP_SECURE=false
#
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@oustadi.ma

# ─── Google OAuth ─────────────────────────────────
# Required for "Continue with Google" button
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create an OAuth 2.0 Client ID (Web application)
# 3. Set Authorized redirect URI:
#    http://192.168.0.202/api/auth/google/callback
# 4. Copy the Client ID and Client Secret below
#
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Also set this to "true" in infra/.env when Google OAuth is configured
# (controls whether the Google button appears on login/register pages)
# NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=true

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
